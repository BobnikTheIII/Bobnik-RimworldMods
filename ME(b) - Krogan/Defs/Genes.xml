  </HeadTypeDef>

  <GeneDef>
    <defName>Krogan_Head</defName>
    <label>krogan head</label>
    <labelShortAdj>krogan</labelShortAdj>
    <description>Carriers of this possess a grunty wide head.</description>
    <biostatCpx>1</biostatCpx>
    <!-- <biostatMet>-1</biostatMet> -->
    <displayCategory>MebUtility</displayCategory>
    <displayOrderInCategory>401</displayOrderInCategory>
    <iconPath>UI/Icons/Krogan_XenotypeIcon</iconPath>
    <iconColor>(0.75, 0.75, 0.75)</iconColor>
    <forcedHeadTypes>
      <li>Female_MEb_Krogan_HeadType</li>
      <li>Male_MEb_Krogan_HeadType</li>
    </forcedHeadTypes>
    <beardTagFilter>
      <whitelist>true</whitelist>
    </beardTagFilter>
    <exclusionTags>
      <li>Fur</li>
      <li>BeardStyle</li>
    </exclusionTags>
  </GeneDef>

  <GeneDef ParentName="GeneMebUtilityCrestsBase">
    <defName>Krogan_Crest_White</defName>
    <label>white krogan crest</label>
    <description>Carriers of this gene possess a white hard strucured, scaled crests.</description>
    <iconPath>Things/Pawn/Humanlike/HeadAttachments/KroganWhite/KroganCrest_White_south</iconPath>
    <displayCategory>MebUtility</displayCategory>
    <displayOrderInCategory>14</displayOrderInCategory>
    <!-- <exclusionTags>
      <li>HairStyle</li>
      <li>BeardStyle</li>
    </exclusionTags>
    <hairTagFilter>
      <whitelist>true</whitelist>
      <tags>
        <li>Bald</li>
      </tags>
    </hairTagFilter>
    <beardTagFilter>
      <whitelist>true</whitelist>
      <tags>
        <li>NoBeard</li>
      </tags>
    </beardTagFilter> -->
    <renderNodeProperties>
      <li>
        <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
        <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
        <texPath>Things/Pawn/Humanlike/HeadAttachments/KroganWhite/MEb_KroganCrest_White</texPath>
        <!-- <colorType>Skin</colorType> -->
        <parentTagDef>Head</parentTagDef>
        <useSkinShader>true</useSkinShader>
        <useRottenColor>true</useRottenColor>
        <rotDrawMode>Fresh, Rotting</rotDrawMode>
        <drawData>
          <defaultData>
            <layer>60</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </GeneDef>

