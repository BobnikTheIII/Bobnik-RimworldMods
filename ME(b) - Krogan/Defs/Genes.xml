    <label>krogan red crest</label>
    <description>Carriers of this gene possess semi-flexible, cartilage-based scalp-crests.</description>
    <iconPath>Things/Pawn/Humanlike/HeadAttachments/KroganRed/KroganCrest_Red_east</iconPath>
    <displayCategory>MebUtility</displayCategory>
    <displayOrderInCategory>12</displayOrderInCategory>
    <renderNodeProperties>
      <li>
        <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
        <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
        <texPath>Things/Pawn/Humanlike/HeadAttachments/KroganRed/KroganCrest_Red</texPath>
