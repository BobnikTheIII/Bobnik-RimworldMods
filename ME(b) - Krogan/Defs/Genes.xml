<Defs>

<!-- Head Accesories -->

  <HeadTypeDef ParentName="AverageBase">
    <defName>Female_MEb_Krogan_HeadType</defName>
    <graphicPath>Things/Pawn/Humanlike/Heads/Female_MEb_Krogan</graphicPath>
    <randomChosen>false</randomChosen>
    <gender>None</gender>
    <requiredGenes>
      <li>Krogan_Head</li>
    </requiredGenes>
    <eyeOffsetEastWest>(0.15, 0, 0.17)</eyeOffsetEastWest>
  </HeadTypeDef>

  <HeadTypeDef ParentName="AverageBase">
    <defName>Male_MEb_Krogan_HeadType</defName>
