<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Pawns -->

  <RulePackDef>
    <defName>MebAsariNamer</defName>
    <rulePack>
      <rulesStrings>
        <li>r_name->[firstname] [prefixLastname]</li>

        <li>prefixLastname->[prefix][lastname]</li>

        <li>prefix->T'</li>
        <li>prefix->D'</li>
        <li>prefix->V'</li>
        <li>prefix->M'</li>
        <li>prefix->Yh'</li>
      </rulesStrings>
      <rulesFiles>
        <li>firstname->Names/AsariPawnFirstNames</li>
        <li>lastname->Names/AsariPawnLastNames</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>

</Defs>