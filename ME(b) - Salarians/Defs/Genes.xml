<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<!-- Head Accesories -->

  <GeneDef ParentName="GeneMebUtilityCrestsBase">
    <defName>Salarian_Crest</defName>
    <label>salarian crest</label>
    <description>Carriers of this gene possess a hard strucured, scaled crests.</description>
    <!-- <iconPath>Things/Pawn/Humanlike/HeadAttachments/KroganWhite/KroganCrest_White_south</iconPath> -->
    <iconPath>Things/Pawn/Humanlike/HeadAttachments/Salarian/Salarian_Crest_south</iconPath>
    <displayCategory>MebUtility</displayCategory>
    <displayOrderInCategory>15</displayOrderInCategory>
    <renderNodeProperties>
      <li>
        <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
        <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
        <texPath>Things/Pawn/Humanlike/HeadAttachments/Salarian/Salarian_Crest</texPath>
        <colorType>Skin</colorType>
        <parentTagDef>Head</parentTagDef>
        <useSkinShader>true</useSkinShader>
        <useRottenColor>true</useRottenColor>
        <rotDrawMode>Fresh, Rotting</rotDrawMode>
        <drawData>
          <defaultData>
            <layer>60</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </GeneDef>

  <GeneDef>
    <defName>Salarian_Head</defName>
    <label>salarian head</label>
    <labelShortAdj>salarian</labelShortAdj>
    <description>Carriers of this possess a thin elongated head.</description>
    <biostatCpx>1</biostatCpx>
    <!-- <biostatMet>-1</biostatMet> -->
    <displayCategory>MebUtility</displayCategory>
    <displayOrderInCategory>400</displayOrderInCategory>
    <iconPath>Things/Pawn/Humanlike/Heads/MEb_Salarian_south</iconPath>
    <iconColor>(0.75, 0.75, 0.75)</iconColor>
    <forcedHeadTypes>
      <li>Salarian_HeadType</li>
    </forcedHeadTypes>
    <beardTagFilter>
      <whitelist>true</whitelist>
    </beardTagFilter>
    <exclusionTags>
      <li>Fur</li>
      <li>BeardStyle</li>
    </exclusionTags>
  </GeneDef>

</Defs>
