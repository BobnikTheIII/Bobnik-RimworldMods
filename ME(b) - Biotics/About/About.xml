      <downloadUrl>https://github.com/pardeike/HarmonyRimWorld/releases/latest</downloadUrl>
    </li>
    <li>
      <packageId>OskarPotocki.VanillaFactionsExpanded.Core</packageId>
      <displayName>Vanilla Expanded Framework</displayName>
